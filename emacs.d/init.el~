;; lsp mode
(require 'lsp-mode)
(require 'lsp-clients)
(require 'lsp-java)
(require 'lsp-ui)
;; (setq lsp-prefer-flymake nil)
(add-hook 'java-mode-hook #'lsp)
(add-hook 'python-mode-hook #'lsp)
(add-hook 'c-mode-hook #'lsp)
(add-hook 'c++-mode-hook #'lsp)
